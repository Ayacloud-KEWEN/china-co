# DeepSeek API (OpenAI-compatible). Get a key at https://platform.deepseek.com
# Copy this file to .env.local and fill in your key.
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# PostgreSQL. For local Docker (docker compose up -d) use the line below.
# For Neon / Supabase / any cloud Postgres, paste that connection string instead.
DATABASE_URL=postgres://chinamos:chinamos@localhost:5544/chinamos

# Admin console (/admin). Comma-separated emails granted platform-admin access.
# Bootstraps the first admin before anyone can be promoted via the DB is_admin flag.
ADMIN_EMAILS=fdcaptain@gmail.com
